{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@docgen/core": ["packages/core/dist"],
      "@docgen/cli": ["packages/cli/dist"],
      "@docgen/parser-typescript": ["packages/parser-typescript/dist"],
      "@docgen/renderer-markdown": ["packages/renderer-markdown/dist"],
      "@docgen/renderer-pdf": ["packages/renderer-pdf/dist"]
    },
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
